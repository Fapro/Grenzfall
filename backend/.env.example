ALLOWED_ORIGINS=https://your-netlify-site.netlify.app

# --- Emergency Recovery ---
# Enables POST /api/auth/recovery/reset-shared-password
# Set a strong random value and keep it secret.
RECOVERY_RESET_TOKEN=change-me-to-a-long-random-secret
