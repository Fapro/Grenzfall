{
  "name": "roar",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File ./frontend/start-frontend.ps1",
    "start:frontend": "powershell -ExecutionPolicy Bypass -File ./frontend/start-frontend.ps1",
    "start:expo": "expo start",
    "start:tunnel": "expo start --tunnel",
    "start:stable": "bash ./scripts/start-expo-stable.sh lan",
    "start:stable:tunnel": "bash ./scripts/start-expo-stable.sh tunnel",
    "start:clear": "expo start -c",
    "android": "expo start --android",
    "android:tunnel": "expo start --tunnel --android",
    "android:stable": "bash ./scripts/start-expo-stable.sh lan",
    "android:stable:tunnel": "bash ./scripts/start-expo-stable.sh tunnel",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:stable": "bash ./scripts/start-expo-stable.sh web",
    "build:web": "npx expo export --platform web"
  },
  "dependencies": {
    "expo": "^55.0.23",
    "expo-av": "^16.0.8",
    "expo-constants": "~55.0.16",
    "expo-haptics": "~55.0.14",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "typescript": "~5.9.2"
  },
  "private": true
}
